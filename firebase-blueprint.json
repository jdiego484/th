{
  "entities": {
    "UserPublic": {
      "title": "Public User Profile",
      "description": "Publicly accessible user information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "city": { "type": "string" },
        "role": { "type": "string", "enum": ["personal", "student"] },
        "personalCode": { "type": "string" },
        "gender": { "type": "string" },
        "crefNumber": { "type": "string" },
        "personalId": { "type": "string", "description": "ID of the personal trainer connected to this student." },
        "stripeConnected": { "type": "boolean", "description": "Whether the personal trainer has connected their Stripe account." }
      },
      "required": ["name", "role"]
    },
    "UserPrivate": {
      "title": "Private User Data",
      "description": "Sensitive user information accessible only by the owner.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "birthDate": { "type": "string" },
        "cep": { "type": "string" },
        "address": { "type": "string" },
        "medicalHistory": { "type": "string" },
        "medications": { "type": "string" },
        "personalId": { "type": "string", "description": "ID of the personal trainer connected to this student." },
        "stripeAccountId": { "type": "string", "description": "The Stripe Connect account ID for the personal trainer." }
      },
      "required": ["email"]
    },
    "UserEmail": {
      "title": "Email Lookup",
      "description": "Mapping from email to UID for fast lookups.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Connection": {
      "title": "Trainer-Student Connection",
      "description": "Represents a link between a personal trainer and a student.",
      "type": "object",
      "properties": {
        "personalId": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "blocked", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personalId", "studentId", "status", "createdAt"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Invitation sent by a trainer to a student.",
      "type": "object",
      "properties": {
        "personalId": { "type": "string" },
        "studentEmail": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personalId", "studentEmail", "status", "createdAt"]
    },
    "Workout": {
      "title": "Workout Plan",
      "description": "A workout plan assigned to a student.",
      "type": "object",
      "properties": {
        "personalId": { "type": "string" },
        "studentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personalId", "studentId", "title", "createdAt"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "An exercise within a workout.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sets": { "type": "string" },
        "reps": { "type": "string" },
        "rest": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name"]
    },
    "Assessment": {
      "title": "Physical Assessment",
      "description": "Physical assessment data for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "personalId": { "type": "string" },
        "weight": { "type": "number" },
        "bodyFat": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "personalId", "createdAt"]
    },
    "Chat": {
      "title": "Chat Room",
      "description": "A chat room between participants.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "SystemMessage": {
      "title": "System Message",
      "description": "System-wide message.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "/users_public/{uid}": {
      "schema": "UserPublic",
      "description": "Public user profiles."
    },
    "/users_private/{uid}": {
      "schema": "UserPrivate",
      "description": "Private user data."
    },
    "/user_emails/{email}": {
      "schema": "UserEmail",
      "description": "Email to UID mapping."
    },
    "/connections/{connectionId}": {
      "schema": "Connection",
      "description": "Trainer-student connections."
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Invitations."
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Workout plans."
    },
    "/workouts/{workoutId}/exercises/{exerciseId}": {
      "schema": "Exercise",
      "description": "Exercises within a workout."
    },
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Physical assessments."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat rooms."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a chat room."
    },
    "/system_messages/{messageId}": {
      "schema": "SystemMessage",
      "description": "System messages."
    }
  }
}
