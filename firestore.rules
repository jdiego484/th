rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == "jdiego484@gmail.com" || 
        request.auth.token.email == "jdiego484@hotmail.com"
      );
    }

    // account_cleanup - used for logging or tracking deletion process
    match /account_cleanup/{uid} {
      allow create: if isAuth() && request.auth.uid == uid;
      allow update, delete: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
    }

    // USERS PUBLIC
    match /users_public/{uid} {
      allow read: if isAuth();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin() || resource == null;
    }

    // USERS PRIVATE
    match /users_private/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) || isAdmin() || resource == null;
      allow delete: if isOwner(uid) || isAdmin() || resource == null;
    }
    
    // USER EMAILS
    match /user_emails/{email} {
      allow read: if isAuth();
      allow write: if isAuth() || resource == null;
    }

    // CONNECTIONS
    match /connections/{id} {
      allow read, update: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );
      allow delete: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );
      allow create: if isAuth();
    }

    // WORKOUTS
    match /workouts/{workoutId} {
      allow create: if isAuth();
      allow read, update: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );
      allow delete: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );

      // SUBCOLLECTION EXERCISES
      match /exercises/{exerciseId} {
        allow read, write: if isAuth() && (
          isAdmin() || 
          get(/databases/$(database)/documents/workouts/$(workoutId)).data.personalId == request.auth.uid || 
          get(/databases/$(database)/documents/workouts/$(workoutId)).data.studentId == request.auth.uid
        );
      }
    }

    // ASSESSMENTS
    match /assessments/{id} {
      allow create: if isAuth();
      allow read, update: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );
      allow delete: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid)
      );
    }

    // CHATS
    match /chats/{id} {
      allow read, write: if isAuth();
    }

    // INVITATIONS
    match /invitations/{id} {
      allow read, update: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid || resource.data.studentEmail == request.auth.token.email)
      );
      allow delete: if isAuth() && (
        isAdmin() || 
        resource == null ||
        (resource.data.personalId == request.auth.uid || resource.data.studentId == request.auth.uid || resource.data.studentEmail == request.auth.token.email)
      );
      allow create: if isAuth();
    }

    // SYSTEM MESSAGES
    match /system_messages/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
