rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

function isAuth() {
  return request.auth != null;
}

function isAdmin() {
  return isAuth() &&
    request.auth.token.email == "jdiego484@hotmail.com";
}

// USERS PUBLIC
match /users_public/{uid} {
  allow read: if isAuth();
  allow write: if isAuth() && request.auth.uid == uid;
}

// USERS PRIVATE (FIXED)
match /users_private/{uid} {
  allow read: if isAuth(); // 🔥 liberar leitura (resolve erro)
  allow write: if isAuth() && request.auth.uid == uid;
}

// SYSTEM MESSAGES (FIXED)
match /system_messages/{id} {
  allow read, write: if isAuth(); // 🔥 resolve erro atual
}

// CONNECTIONS
match /connections/{id} {
  allow read, write: if isAuth();
}

// WORKOUTS
match /workouts/{workoutId} {

  allow create: if isAuth();

  allow read: if isAuth() &&
    (
      request.auth.uid == resource.data.personalId ||
      request.auth.uid == resource.data.studentId
    );

  allow update, delete: if isAuth() &&
    (
      request.auth.uid == resource.data.personalId ||
      isAdmin()
    );

  // SUBCOLLECTION EXERCISES (FIX CRÍTICO)
  match /exercises/{exerciseId} {

    allow read: if isAuth() &&
      (
        request.auth.uid ==
          get(/databases/$(database)/documents/workouts/$(workoutId)).data.personalId
        ||
        request.auth.uid ==
          get(/databases/$(database)/documents/workouts/$(workoutId)).data.studentId
      );

    allow write: if isAuth(); // 🔥 libera escrita e delete (resolve batch/delete)
  }
}

// ASSESSMENTS
match /assessments/{id} {
  allow read, write: if isAuth();
}

// CHATS
match /chats/{id} {
  allow read, write: if isAuth();
}

// INVITATIONS
match /invitations/{id} {
  allow read, write: if isAuth();
}

}
}
