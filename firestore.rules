rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users_public
    // Document ID: {uid}
    // Fields:
    //   - name: string (required)
    //   - photoUrl: string (optional)
    //   - city: string (optional)
    //   - role: string (required, enum: ['personal', 'student', 'superadmin'])
    //   - personalCode: string (optional)
    //   - profileCompleted: bool (optional)
    //   - createdAt: string (ISO 8601)
    //
    // Collection: users_private
    // Document ID: {uid}
    // Fields:
    //   - email: string (required)
    //   - cpf: string (optional)
    //   - medicalHistory: string (optional)
    //   - medications: string (optional)
    //
    // Collection: user_emails
    // Document ID: {email}
    // Fields:
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isConnectedTrainer(studentId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/connections/$(request.auth.uid + "_" + studentId)) &&
        get(/databases/$(database)/documents/connections/$(request.auth.uid + "_" + studentId)).data.status == "active";
    }

    function isConnectedStudent(trainerId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/connections/$(trainerId + "_" + request.auth.uid)) &&
        get(/databases/$(database)/documents/connections/$(trainerId + "_" + request.auth.uid)).data.status == "active";
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "jdiego484@gmail.com" || 
         (exists(/databases/$(database)/documents/users_public/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users_public/$(request.auth.uid)).data.role == "superadmin"));
    }

    function isValidUserPublic(data) {
      return data.keys().hasAll(['name', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['personal', 'student', 'superadmin', 'client'];
    }

    function isValidUserPrivate(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() >= 2 && data.phone.size() < 20));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Legacy Users Collection (for safety during transition)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Public User Profiles
    match /users_public/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUserPublic(request.resource.data);
      allow update: if (isOwner(uid) && isValidUserPublic(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    // Private User Data
    match /users_private/{uid} {
      allow read: if isOwner(uid) || isConnectedTrainer(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUserPrivate(request.resource.data);
      allow update: if (isOwner(uid) && isValidUserPrivate(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    // Email Lookup
    match /user_emails/{email} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Connections
    match /connections/{connectionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.personalId || request.auth.uid == request.resource.data.studentId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
    }

    // Invitations
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || request.auth.token.email == resource.data.studentEmail || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.personalId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || request.auth.token.email == resource.data.studentEmail || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
    }

    // Workouts
    match /workouts/{workoutId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.personalId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
    }

    // Exercises
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated(); 
      allow create, update, delete: if isAuthenticated(); 
    }

    // Assessments
    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.personalId || isAdmin());
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
    }

    // Chats
    match /chats/{chatId} {
      function isParticipant(participants) {
        return isAuthenticated() && request.auth.uid in participants;
      }

      allow read: if isParticipant(resource.data.participants);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants) && request.resource.data.senderId == request.auth.uid;
      }
    }

    // System Messages
    match /system_messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
