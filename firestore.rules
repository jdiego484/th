rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // FUNÇÕES AUXILIARES (Padrão Profissional)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "jdiego484@gmail.com" ||
        (exists(/databases/$(database)/documents/users_public/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users_public/$(request.auth.uid)).data.role == "superadmin")
      );
    }

    // Validação básica de segurança para strings
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // REGRAS DE COLEÇÕES
    // ===============================================================

    // Perfil Público
    match /users_public/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid); // Simples para não quebrar o registro
      allow update: if isAdmin() || (
        isOwner(uid) && 
        // SEGURANÇA CRÍTICA: Usuário não pode mudar seu próprio cargo (role)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) &&
        isValidString(request.resource.data.name, 100)
      );
      allow delete: if isAdmin();
    }

    // Dados Privados
    match /users_private/{uid} {
      allow read: if isOwner(uid) || isAdmin() || 
        exists(/databases/$(database)/documents/connections/$(request.auth.uid + "_" + uid));
      allow create: if isOwner(uid);
      allow update: if isAdmin() || (
        isOwner(uid) && 
        isValidString(request.resource.data.get('phone', ''), 30)
      );
      allow delete: if isAdmin();
    }

    // Mapeamento de E-mail
    match /user_emails/{email} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    // Conexões
    match /connections/{connectionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.personalId || 
        request.auth.uid == resource.data.studentId || 
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.personalId || 
        request.auth.uid == resource.data.studentId || 
        isAdmin()
      );
    }

    // Convites, Treinos, Avaliações e Chats
    match /invitations/{id} { allow read, write: if isAuthenticated(); }
    match /workouts/{id} { 
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
    }
    match /exercises/{id} { allow read, write: if isAuthenticated(); }
    match /assessments/{id} { 
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.personalId || request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.personalId || isAdmin());
    }
    match /chats/{id} { 
      allow read, write: if isAuthenticated();
      match /messages/{mid} { allow read, write: if isAuthenticated(); }
    }
    match /system_messages/{id} { 
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
